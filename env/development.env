# Local development environment defaults
APP_ENV=development
LOG_LEVEL=debug
DEBUG_MODE=true
RBAC_ENFORCE=false

API_PORT=8080
WEB_PORT=4173
VEMS_DB_PATH=.data/platform.development.sqlite

SYNC_WORKER_POLL_INTERVAL_MS=2000
SYNC_WORKER_BATCH_SIZE=100
SYNC_WORKER_MAX_ATTEMPTS=3

# Placeholder integration values to keep startup deterministic in local mode.
JWT_ISSUER=local-dev
JWT_AUDIENCE=vems-platform
JWT_PUBLIC_KEY=local-dev-public-key
DATABASE_URL=sqlite://.data/platform.development.sqlite
REDIS_URL=redis://localhost:6379
EVENT_BUS_URL=memory://local
VTIGER_BASE_URL=http://localhost:8888
VTIGER_USERNAME=local-dev
VTIGER_ACCESS_KEY=__set_in_local_env__
OPENEMR_BASE_URL=http://localhost:8300
OPENEMR_CLIENT_ID=local-dev-client
OPENEMR_CLIENT_SECRET=__set_in_local_env__
OPENEMR_TOKEN_URL=http://localhost:8300/oauth2/default/token

# Optional upstream connectivity checks (disabled by default for offline-safe local dev).
SMOKE_INCLUDE_UPSTREAM_CONNECTIVITY=false
UPSTREAM_CONNECTIVITY_CHECKS_ENABLED=false
UPSTREAM_CONNECTIVITY_TARGETS=vtiger,openemr
VALIDATION_TIMEOUT_MS=4000
VTIGER_CONNECTIVITY_PING_PATH=/
VTIGER_CONNECTIVITY_CHECK_AUTH=false
OPENEMR_CONNECTIVITY_PING_PATH=/
OPENEMR_CONNECTIVITY_CHECK_AUTH=false

AUTH_TRUST_HEADERS=false
JWT_HS256_SECRET=__set_in_local_env__
