# Staging-like local defaults (safe placeholders)
APP_ENV=staging
LOG_LEVEL=info
DEBUG_MODE=false
RBAC_ENFORCE=true

API_PORT=8080
WEB_PORT=4173
VEMS_DB_PATH=.data/platform.staging.sqlite

SYNC_WORKER_POLL_INTERVAL_MS=2000
SYNC_WORKER_BATCH_SIZE=100
SYNC_WORKER_MAX_ATTEMPTS=3

JWT_ISSUER=staging-placeholder
JWT_AUDIENCE=vems-platform
JWT_PUBLIC_KEY=staging-placeholder-public-key
DATABASE_URL=sqlite://.data/platform.staging.sqlite
REDIS_URL=redis://staging-redis:6379
EVENT_BUS_URL=nats://staging-nats:4222
VTIGER_BASE_URL=https://vtiger.staging.example
VTIGER_USERNAME=staging-service
VTIGER_ACCESS_KEY=__set_in_local_env__
OPENEMR_BASE_URL=https://openemr.staging.example
OPENEMR_CLIENT_ID=staging-client
OPENEMR_CLIENT_SECRET=__set_in_local_env__
OPENEMR_TOKEN_URL=https://openemr.staging.example/oauth2/default/token

# Optional upstream connectivity checks (enable in staging-like runs when systems are reachable).
SMOKE_INCLUDE_UPSTREAM_CONNECTIVITY=false
UPSTREAM_CONNECTIVITY_CHECKS_ENABLED=false
UPSTREAM_CONNECTIVITY_TARGETS=vtiger,openemr
VALIDATION_TIMEOUT_MS=4000
VTIGER_CONNECTIVITY_PING_PATH=/
VTIGER_CONNECTIVITY_CHECK_AUTH=true
OPENEMR_CONNECTIVITY_PING_PATH=/
OPENEMR_CONNECTIVITY_CHECK_AUTH=true

AUTH_TRUST_HEADERS=false
JWT_HS256_SECRET=__set_in_local_env__
