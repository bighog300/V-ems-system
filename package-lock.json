{
  "name": "v-ems-system",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "v-ems-system",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "services/*"
      ]
    },
    "node_modules/@vems/api-gateway": {
      "resolved": "services/api-gateway",
      "link": true
    },
    "node_modules/@vems/orchestration": {
      "resolved": "services/orchestration",
      "link": true
    },
    "node_modules/@vems/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@vems/shared",
      "version": "0.1.0"
    },
    "services/api-gateway": {
      "name": "@vems/api-gateway",
      "version": "0.1.0",
      "dependencies": {
        "@vems/orchestration": "0.1.0",
        "@vems/shared": "0.1.0"
      }
    },
    "services/orchestration": {
      "name": "@vems/orchestration",
      "version": "0.1.0",
      "dependencies": {
        "@vems/shared": "0.1.0"
      }
    }
  }
}
